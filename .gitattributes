# Cross-platform line-ending normalization for this repo.
# See https://git-scm.com/docs/gitattributes

# Auto-detect and normalize text files in the repo to LF.
* text=auto eol=lf

# Force LF for everything that's run on Linux/macOS.
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Force CRLF for everything that's run on Windows.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Mark common binaries explicitly so git doesn't try to diff them.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
